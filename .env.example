# Copy to `.env` and fill in values. Required keys are validated at startup via `shared/lib/env.ts`.
# Skip validation for one-off scripts: SKIP_ENV_VALIDATION=1

# --- Required ---
DATABASE_URL=postgresql://user:pass@host:5432/postgres
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# --- Auth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI / media (set what you use) ---
FAL_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
PIXABAY_API_KEY=

# --- Storage & webhooks ---
# Set by `pnpm dev` (cloudflared) or your public URL:
WEBHOOK_BASE_URL=
PUBLIC_BASE_URL=

# --- Defaults ---
IMAGE_MODEL=flux-schnell-fal
MUSIC_MODEL=minimax

# --- Polar billing (optional) ---
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_ENVIRONMENT=sandbox
POLAR_SUCCESS_URL=
POLAR_PRODUCT_STARTER=
POLAR_PRODUCT_PRO=
POLAR_PRODUCT_CREDITS_SMALL=
POLAR_PRODUCT_CREDITS_LARGE=

# --- Dev ---
PORT=3000
WEBHOOK_SKIP_TUNNEL=0
